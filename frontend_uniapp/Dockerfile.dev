FROM node:20-slim

WORKDIR /app

# 复制 docker-entrypoint.sh
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN mv /docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh && chmod +x /usr/local/bin/docker-entrypoint.sh

# 运行镜像源配置（在构建时设置）
RUN /usr/local/bin/docker-entrypoint.sh true || true

# 安装系统依赖（openssl for uni-app）
RUN apt-get update && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*

# 复制 package.json 并安装依赖
COPY package*.json ./
RUN npm install

# 端口暴露
EXPOSE 5173

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["npm", "run", "dev:h5", "--", "--host"]
